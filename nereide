  .service-card.featured { background:var(--brown); border-top-color:var(--gold); }
  .service-card.featured:hover { background:#4a3520; }
  .service-num { font-family:'Playfair Display',serif; font-size:11px; color:var(--gold); letter-spacing:.1em; margin-bottom:20px; display:block; }
  .service-icon { font-size:28px; margin-bottom:16px; display:block; }
  .service-name { font-family:'Playfair Display',serif; font-size:20px; font-weight:400; color:var(--brown); margin-bottom:6px; line-height:1.2; }
  .featured .service-name { color:var(--cream); }
  .service-name-en { font-size:11px; color:var(--muted); letter-spacing:.06em; margin-bottom:16px; display:block; }
  .featured .service-name-en { color:rgba(247,242,232,.5); }
  .service-desc { font-size:13px; line-height:1.75; color:var(--mid); }
  .featured .service-desc { color:var(--muted); }
  .service-link { display:inline-flex; align-items:center; gap:8px; font-size:10px; letter-spacing:.15em; text-transform:uppercase; color:var(--gold); margin-top:24px; text-decoration:none; transition:gap .2s; }
  .service-link:hover { gap:14px; }
  .featured .service-link { color:var(--gold-lt); }
  .service-card::after { content:''; position:absolute; bottom:0; left:0; right:0; height:2px; background:var(--gold); transform:scaleX(0); transition:transform .3s; transform-origin:left; }
  .service-card:hover::after,.service-card.featured::after { transform:scaleX(1); }
  #dinner { padding:100px 0; background:var(--cream); }
  .dinner-grid { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:start; margin-top:60px; }
  .dinner-menu-title { font-family:'Playfair Display',serif; font-size:13px; font-style:italic; color:var(--gold); letter-spacing:.08em; margin-bottom:24px; }
  .menu-course { display:flex; gap:16px; padding:14px 0; border-bottom:.5px solid rgba(139,105,20,.15); align-items:start; }
  .menu-course:last-child { border-bottom:none; }
  .course-n { font-family:'Playfair Display',serif; font-size:11px; color:var(--gold-lt); min-width:20px; padding-top:2px; }
  .course-info { flex:1; }
  .course-name-it { font-size:14px; font-weight:400; color:var(--brown); margin-bottom:2px; }
  .course-name-en { font-size:11px; color:var(--muted); font-style:italic; }
  .info-block { background:var(--warm); padding:28px; margin-bottom:16px; border-left:2px solid var(--gold); }
  .info-block-title { font-size:9px; letter-spacing:.18em; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
  .info-block-text { font-size:13px; line-height:1.7; color:var(--mid); }
  .info-block-text strong { color:var(--brown); font-weight:400; }
  #wines { padding:100px 0; background:var(--brown); }
  #wines .section-tag { color:var(--gold-lt); }
  #wines .section-title { color:var(--cream); }
  .wines-intro { font-size:15px; line-height:1.8; color:var(--muted); margin-top:24px; max-width:560px; }
  .wines-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:2px; margin-top:60px; }
  .wine-card { background:rgba(255,255,255,.04); border:.5px solid rgba(196,164,74,.2); padding:32px 28px; transition:background .3s; }
  .wine-card:hover { background:rgba(255,255,255,.08); }
  .wine-type { font-size:9px; letter-spacing:.2em; text-transform:uppercase; color:var(--gold-lt); margin-bottom:12px; display:block; }
  .wine-name { font-family:'Playfair Display',serif; font-size:18px; color:var(--cream); margin-bottom:4px; }
  .wine-producer { font-size:11px; color:var(--muted); margin-bottom:14px; }
  .wine-desc { font-size:12px; line-height:1.7; color:rgba(156,126,90,.9); }
  #contact { padding:100px 0; background:var(--warm); }
  .contact-grid { display:grid; grid-template-columns:1fr 1fr; gap:80px; margin-top:60px; }
  .contact-info p { font-size:14px; line-height:1.85; color:var(--mid); margin-bottom:32px; }
  .contact-detail { display:flex; flex-direction:column; gap:12px; margin-bottom:32px; }
  .contact-detail-item { display:flex; gap:12px; align-items:baseline; }
  .contact-detail-label { font-size:9px; letter-spacing:.15em; text-transform:uppercase; color:var(--gold); min-width:80px; }
  .contact-detail-value { font-size:13px; color:var(--mid); }
  .form-group { margin-bottom:20px; }
  .form-group label { display:block; font-size:9px; letter-spacing:.15em; text-transform:uppercase; color:var(--gold); margin-bottom:8px; }
  .form-group input,.form-group select,.form-group textarea { width:100%; background:var(--cream); border:.5px solid rgba(139,105,20,.3); padding:12px 16px; font-family:'Lato',sans-serif; font-size:13px; color:var(--brown); font-weight:300; outline:none; transition:border-color .2s; appearance:none; }
  .form-group input:focus,.form-group select:focus,.form-group textarea:focus { border-color:var(--gold); }
  .form-group textarea { resize:vertical; min-height:100px; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  footer { background:var(--brown); padding:48px 40px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:20px; border-top:.5px solid rgba(196,164,74,.2); }
  .footer-logo { font-family:'Playfair Display',serif; font-size:18px; font-style:italic; color:var(--cream); }
  .footer-logo span { color:var(--gold-lt); }
  .footer-text { font-size:11px; color:var(--muted); text-align:center; }
  .footer-links { display:flex; gap:24px; }
  .footer-links a { font-size:10px; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); text-decoration:none; transition:color .2s; }
  .footer-links a:hover { color:var(--gold-lt); }
  .ornament { display:flex; align-items:center; gap:16px; margin-bottom:32px; }
  .ornament-line { flex:0 0 40px; height:.5px; background:var(--gold); }
  .ornament-text { font-size:9px; letter-spacing:.2em; text-transform:uppercase; color:var(--gold); }
  @keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
  @keyframes scrollPulse { 0%,100%{opacity:.3;transform:scaleY(.8)} 50%{opacity:1;transform:scaleY(1)} }
  .reveal { opacity:0; transform:translateY(20px); transition:opacity .7s ease,transform .7s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }
  [data-en] { display:none; }
  body.en [data-it] { display:none; }
  body.en [data-en] { display:revert; }
  @media(max-width:768px){
    nav{padding:14px 20px} .nav-links{display:none} .section-inner{padding:0 20px}
    .intro-grid,.dinner-grid,.contact-grid{grid-template-columns:1fr;gap:40px}
    .services-grid{grid-template-columns:1fr} footer{flex-direction:column;text-align:center} #hero{padding:80px 20px 60px}
  }
</style>
</head>
<body>

<nav>
  <div class="nav-logo">Villa <span>Nereide</span></div>
