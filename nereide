  html { scroll-behavior: smooth; }
  body { font-family:'Lato',sans-serif; background:var(--cream); color:var(--brown); font-weight:300; overflow-x:hidden; }
  body::before { content:''; position:fixed; inset:0; pointer-events:none; z-index:0;
