<script>
function setLang(lang){
  document.querySelectorAll('[data-it]').forEach(el=>el.style.display=lang==='en'?'none':'');
  document.querySelectorAll('[data-en]').forEach(el=>el.style.display=lang==='en'?'':'none');
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.remove('active'));
  document.querySelector(`.lang-btn[onclick="setLang('${lang}')"]`).classList.add('active');
}
const obs=new IntersectionObserver(entries=>entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')}),{threshold:.1});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
document.querySelectorAll('.service-card').forEach((c,i)=>c.style.transitionDelay=`${i*.07}s`);
// init: hide [data-en] on load
document.querySelectorAll('[data-en]').forEach(el=>el.style.display='none');
</script>
