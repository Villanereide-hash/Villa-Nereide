  .services-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:2px; }
  .service-card { background:var(--cream); padding:40px 32px; position:relative; overflow:hidden; cursor:pointer; transition:background .3s; border-top:3px solid transparent; }
