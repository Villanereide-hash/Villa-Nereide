<title>Villa Nereide · Cinisi, Sicilia</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&family=Lato:wght@300;400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --cream:#F7F2E8; --warm:#EDE3CC; --gold:#8B6914; --gold-lt:#C4A44A;
