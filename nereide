  .nav-links { display:flex; gap:28px; }
  .nav-links a { font-size:11px; font-weight:400; letter-spacing:.12em; text-transform:uppercase; color:var(--mid); text-decoration:none; transition:color .2s; }
  .nav-links a:hover { color:var(--gold); }
  .nav-lang { display:flex; gap:6px; }
  .lang-btn { background:none; border:.5px solid var(--muted); color:var(--muted); padding:3px 9px; cursor:pointer; font-size:10px; letter-spacing:.1em; transition:all .2s; font-family:'Lato',sans-serif; }
  .lang-btn.active,.lang-btn:hover { background:var(--gold); border-color:var(--gold); color:white; }
  #hero { min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; position:relative; overflow:hidden; background:var(--brown); padding:100px 40px 60px; }
  #hero::before { content:''; position:absolute; width:600px; height:600px; border-radius:50%; border:1px solid rgba(196,164,74,.15); top:50%; left:50%; transform:translate(-50%,-50%); }
  #hero::after { content:''; position:absolute; width:400px; height:400px; border-radius:50%; border:1px solid rgba(196,164,74,.1); top:50%; left:50%; transform:translate(-50%,-50%); }
  .hero-tag { font-size:10px; letter-spacing:.25em; text-transform:uppercase; color:var(--gold-lt); margin-bottom:24px; animation:fadeUp .8s ease both; }
  .hero-title { font-family:'Playfair Display',serif; font-size:clamp(52px,8vw,88px); font-weight:400; color:var(--cream); text-align:center; line-height:1.05; animation:fadeUp .8s .15s ease both; }
  .hero-title em { color:var(--gold-lt); font-style:italic; }
  .hero-sub { font-family:'Playfair Display',serif; font-size:clamp(14px,2vw,18px); font-style:italic; color:var(--muted); text-align:center; margin-top:16px; animation:fadeUp .8s .3s ease both; }
  .hero-location { font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--gold-lt); margin-top:32px; text-align:center; animation:fadeUp .8s .45s ease both; }
  .hero-cta { margin-top:44px; display:flex; gap:16px; flex-wrap:wrap; justify-content:center; animation:fadeUp .8s .6s ease both; }
  .btn-primary { background:var(--gold); color:white; border:none; padding:13px 32px; font-family:'Lato',sans-serif; font-size:11px; letter-spacing:.15em; text-transform:uppercase; cursor:pointer; transition:all .25s; text-decoration:none; display:inline-block; }
  .btn-primary:hover { background:var(--gold-lt); transform:translateY(-1px); }
  .btn-outline { background:transparent; color:var(--cream); border:.5px solid rgba(247,242,232,.4); padding:13px 32px; font-family:'Lato',sans-serif; font-size:11px; letter-spacing:.15em; text-transform:uppercase; cursor:pointer; transition:all .25s; text-decoration:none; display:inline-block; }
  .btn-outline:hover { border-color:var(--gold-lt); color:var(--gold-lt); }
  .hero-scroll { position:absolute; bottom:32px; left:50%; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:8px; animation:fadeUp .8s .9s ease both; }
  .hero-scroll span { font-size:9px; letter-spacing:.2em; color:var(--muted); text-transform:uppercase; }
  .scroll-line { width:1px; height:40px; background:linear-gradient(to bottom,var(--gold-lt),transparent); animation:scrollPulse 1.8s ease-in-out infinite; }
  section { position:relative; z-index:1; }
  .section-inner { max-width:1100px; margin:0 auto; padding:0 40px; }
  .section-tag { font-size:9px; letter-spacing:.22em; text-transform:uppercase; color:var(--gold); margin-bottom:12px; display:block; }
  .section-title { font-family:'Playfair Display',serif; font-size:clamp(32px,4vw,48px); font-weight:400; color:var(--brown); line-height:1.15; }
  .section-title em { color:var(--terra); font-style:italic; }
  #intro { padding:100px 0; background:var(--cream); }
  .intro-grid { display:grid; grid-template-columns:1fr 1fr; gap:80px; align-items:center; margin-top:60px; }
  .intro-text p { font-size:15px; line-height:1.85; color:var(--mid); margin-bottom:20px; }
  .intro-card { background:var(--brown); padding:48px 40px; position:relative; }
  .intro-card::before { content:''; position:absolute; inset:-8px; border:.5px solid rgba(139,105,20,.3); pointer-events:none; }
  .intro-card-title { font-family:'Playfair Display',serif; font-size:13px; font-style:italic; color:var(--gold-lt); letter-spacing:.08em; margin-bottom:20px; }
  .intro-stat { margin-bottom:20px; border-bottom:.5px solid rgba(196,164,74,.2); padding-bottom:20px; }
  .intro-stat:last-child { border-bottom:none; margin-bottom:0; padding-bottom:0; }
  .intro-stat-num { font-family:'Playfair Display',serif; font-size:32px; color:var(--gold-lt); line-height:1; }
  .intro-stat-label { font-size:11px; color:var(--muted); letter-spacing:.08em; margin-top:4px; }
  #services { padding:100px 0; background:var(--warm); }
